<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="MTGA"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- LSPosed module metadata -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposedminversion"
            android:value="93" />
        <!--
            Opt MTGA into LSPosed's world-readable prefs bridge — the
            daemon mirrors MTGA's prefs into a dir readable from any
            hooked process, bypassing both the `<queries>` package
            visibility filter and the SELinux `app_data_file` cross-UID
            barrier. Required for builds whose `<queries>` doesn't match
            our intent-filter trick (Truth Social v1.24.x).
            https://github.com/LSPosed/LSPosed/wiki/New-XSharedPreferences
        -->
        <meta-data
            android:name="xposedsharedprefs"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Ad blocker and feature enhancer for Truth Social" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

        <!--
            SettingsActivity is launched from inside Truth Social via:
              - explicit Intent from TruthSocialPreferencesHook (injected row in TS prefs)
              - explicit Intent from InAppSettingsHook (triple-tap top-left avatar fallback)
            No LAUNCHER intent-filter, so MTGA does not appear in the app drawer.
        -->
        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:label="MTGA settings"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:autoRemoveFromRecents="true">
            <!--
                MTGA needs to be visible to Truth Social's process so the host
                can resolve our ContentProvider authority across Android 11+
                package-visibility filtering. Truth Social's manifest declares
                a generic `<queries><intent>` for VIEW + BROWSABLE + https, so
                publishing a matching (non-default, non-tap-able) intent-filter
                here grants persistent visibility without polluting the user's
                "Open with…" chooser or app drawer. The activity itself stays
                effectively hidden — it's not launched from any HTTP URL flow
                because we register only a scheme with no host pattern.
            -->
            <!--
                CATEGORY_DEFAULT is intentionally OMITTED — without it the
                activity does NOT appear in implicit URL choosers, so the user
                never sees MTGA listed for arbitrary https links. The filter
                is purely a visibility token: Truth Social's manifest already
                declares `<queries><intent>...</intent>` matching this exact
                shape (action VIEW + category BROWSABLE + scheme https, no
                host), so the system grants Truth Social visibility over the
                MTGA package — which in turn lets `ContentResolver.query` on
                `com.example.mtga.settings` succeed.

                Host is also OMITTED so the filter matches Truth Social's
                test intent (which has no specific host).
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
            </intent-filter>
        </activity>

        <!--
            Cross-process IPC bridge for the hooked Truth Social process.
            LSPosed's MODE_WORLD_READABLE redirect does not run for modules
            on the LSPosed denylist (a common default for module packages),
            so XSharedPreferences-based reading silently fails. Instead the
            host queries this provider via ContentResolver — see
            com.example.mtga.config.SettingsContentProvider.

            android:exported="true" is required so callers from other
            packages can resolve the authority. The provider is strictly
            read-only and returns string-serialised values for every
            persisted MTGA setting key (no PII).
        -->
        <provider
            android:name=".config.SettingsContentProvider"
            android:authorities="com.example.mtga.settings"
            android:exported="true"
            android:grantUriPermissions="false" />
    </application>
</manifest>
